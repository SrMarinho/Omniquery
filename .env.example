# ─────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────
DATABASE_USER=usuario
DATABASE_PASSWORD=senha
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=meu_banco

# ─────────────────────────────────────────
# SQL Server (Procfit)
# ─────────────────────────────────────────
PROCFIT_DATABASE_USER=usuario
PROCFIT_DATABASE_PASSWORD=senha
PROCFIT_DATABASE_HOST=localhost
PROCFIT_DATABASE_PORT=1433
PROCFIT_DATABASE_NAME=meu_banco

# ─────────────────────────────────────────
# Oracle (Senior)
# ─────────────────────────────────────────
SENIOR_DATABASE_USER=usuario
SENIOR_DATABASE_PASSWORD=senha
SENIOR_DATABASE_HOST=localhost
SENIOR_DATABASE_PORT=1521
SENIOR_DATABASE_SERVICE_NAME=meu_servico

# ─────────────────────────────────────────
# Logging
# ─────────────────────────────────────────
# Nível de log: DEBUG, INFO, WARNING, ERROR (padrão: INFO)
LOG_LEVEL=INFO

# ─────────────────────────────────────────
# Tuning de transferência (opcional)
# ─────────────────────────────────────────
# Linhas por chunk ao ler de banco de dados (padrão: 500000)
DB_CHUNK_SIZE=500000

# Threads do DuckDB para processamento (padrão: 4)
DB_THREADS=4

# Limite de memória do DuckDB (padrão: 4GB)
DB_MEMORY_LIMIT=4GB

# Linhas por chunk ao escrever CSV (padrão: 100000)
FILE_CHUNK_SIZE=100000

# Linhas por batch ao escrever em banco de dados (padrão: 500000)
DB_BATCH_SIZE=500000
