# ─────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────
DATABASE_USER=user
DATABASE_PASSWORD=password
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=my_database

# ─────────────────────────────────────────
# SQL Server (Procfit)
# ─────────────────────────────────────────
PROCFIT_DATABASE_USER=user
PROCFIT_DATABASE_PASSWORD=password
PROCFIT_DATABASE_HOST=localhost
PROCFIT_DATABASE_PORT=1433
PROCFIT_DATABASE_NAME=my_database

# ─────────────────────────────────────────
# Oracle (Senior)
# ─────────────────────────────────────────
SENIOR_DATABASE_USER=user
SENIOR_DATABASE_PASSWORD=password
SENIOR_DATABASE_HOST=localhost
SENIOR_DATABASE_PORT=1521
SENIOR_DATABASE_SERVICE_NAME=my_service

# ─────────────────────────────────────────
# Logging
# ─────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO

# ─────────────────────────────────────────
# Transfer tuning (optional)
# ─────────────────────────────────────────
# Rows per chunk when reading from databases (default: 500000)
DB_CHUNK_SIZE=500000

# DuckDB worker threads (default: 4)
DB_THREADS=4

# DuckDB memory limit (default: 4GB)
DB_MEMORY_LIMIT=4GB

# Rows per chunk when writing CSV (default: 100000)
FILE_CHUNK_SIZE=100000

# Rows per batch when writing to a database (default: 500000)
DB_BATCH_SIZE=500000
